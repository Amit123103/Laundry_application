    "NEXT_PUBLIC_FIREBASE_PROJECT_ID": "lightingfastlaundry",
    "NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET": "lightingfastlaundry.firebasestorage.app",
    "NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID": "724425779499",
    "NEXT_PUBLIC_FIREBASE_APP_ID": "1:724425779499:web:7911325c636359f3c2bd6e",
    "NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID": "G-S09K2TXVM0"
  }
