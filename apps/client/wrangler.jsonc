{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "lightingfast",
  "compatibility_date": "2026-07-11",
  "observability": {
    "enabled": true
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "main": ".open-next/worker.js",
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "lightingfast"
    }
  ],
  "vars": {
